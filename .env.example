# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Optional: expected `aud` claim on Supabase JWTs (default "authenticated")
SUPABASE_JWT_AUDIENCE=authenticated

# Proxmox
PROXMOX_HOST=proxmox.school.local
PROXMOX_USER=root@pam
PROXMOX_TOKEN_ID=briehost
PROXMOX_TOKEN_SECRET=
PROXMOX_NODE=pve
PHP_TEMPLATE_VMID=9000

# Storage / limits
STORAGE_ROOT=/var/brieblast/clients
MAX_UPLOAD_BYTES=104857600

# CORS — comma-separated list of allowed dashboard origins
ALLOWED_ORIGINS=http://localhost:5173

# API bind settings
API_HOST=0.0.0.0
API_PORT=8000

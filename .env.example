# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
# Optional: expected `aud` claim on Supabase JWTs (default "authenticated")
SUPABASE_JWT_AUDIENCE=authenticated

# Proxmox
PROXMOX_HOST=proxmox.school.local
PROXMOX_USER=root@pam
PROXMOX_TOKEN_ID=briehost
PROXMOX_TOKEN_SECRET=
PROXMOX_NODE=pve
PHP_TEMPLATE_VMID=9000

# Storage / limits
STORAGE_ROOT=/var/brieblast/clients
MAX_UPLOAD_BYTES=104857600

# Provisioning backend
PROVISIONER_BACKEND=ansible
ANSIBLE_PLAYBOOK_PATH=infra/ansible/playbooks/provision_site.yml
ANSIBLE_INVENTORY_PATH=infra/ansible/inventory/production.ini
ANSIBLE_EXTRA_VARS_JSON={}
ANSIBLE_TIMEOUT_SECONDS=1800
MAX_CONCURRENT_PROVISIONS=3

# Malware scanning + zip policy
ENABLE_MALWARE_SCAN=true
CLAMD_SOCKET=/run/clamav/clamd.ctl
CLAMD_HOST=127.0.0.1
CLAMD_PORT=3310
MAX_ZIP_FILES=5000
MAX_ZIP_UNCOMPRESSED_BYTES=524288000
MAX_ZIP_COMPRESSION_RATIO=200

# CORS — comma-separated list of allowed dashboard origins
ALLOWED_ORIGINS=http://localhost:5173

# API bind settings
API_HOST=0.0.0.0
API_PORT=8000
